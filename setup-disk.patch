+# setup limine bootloader
+setup_limine() {
+	local mnt="$1" root="$2" modules="$3" kernel_opts="$4" bootdev="$5"
+	shift 5
+	local limine_dir=
+	if [ -n "$USE_EFI" ]; then
+		local efi_directory
+		efi_directory=$(find_efi_directory "$mnt") || \
+			echo "WARNING: EFI directory was not found" >&2
+		limine_dir="$efi_directory"/limine
+	else
+		limine_dir="$mnt"/boot/limine
+	fi
+	mkdir -p "$limine_dir"
+	cat > "$limine_dir"/limine.conf <<- EOF
+	timeout: 5
+
+	/Alpine Linux
+	    protocol: linux
+	    kernel_path: boot():/vmlinuz-$KERNEL_FLAVOR
+	    kernel_cmdline: root=$root modules=$modules $kernel_opts
+	    module_path: boot():/initramfs-$KERNEL_FLAVOR
+	EOF
+	if [ -n "$USE_EFI" ]; then
+		local fwa
+		case "$ARCH" in
+			x86_64)  fwa=X64 ;;
+			x86)     fwa=IA32 ;;
+			aarch64) fwa=AA64 ;;
+			riscv64) fwa=RISCV64 ;;
+			*) die "Limine EFI is not supported for $ARCH" ;;
+		esac
+		$MOCK install -D /usr/share/limine/BOOT${fwa}.EFI \
+			"$efi_directory"/EFI/BOOT/BOOT${fwa}.EFI
+	else
+		$MOCK cp /usr/share/limine/limine-bios.sys "$limine_dir"/
+		for disk in "$@"; do
+			echo "Installing limine on $disk"
+			$MOCK limine bios-install "$disk"
+		done
+	fi
+}
+
